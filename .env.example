# Docker build options
SEARXNG_GIT_REF=master
CRAWL4AI_PRE_RELEASE=false

# Container and port mapping
WEBSEARCH_CONTAINER_NAME=websearch
WEBSEARCH_API_HOST_PORT=9000
SEARXNG_HOST_PORT=8080

# Runtime config paths
WEBSEARCH_CONFIG_PATH=/app/config/config.yaml
SEARXNG_SETTINGS_PATH=/etc/searxng/settings.yml
WEBSEARCH_OUTPUT_DIR=/app/output

# Secrets (set this in local .env; do not commit real secrets)
SEARXNG_SECRET_KEY=replace-with-a-long-random-secret
